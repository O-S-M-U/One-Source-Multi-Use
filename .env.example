# =====================================================================
# O.S.M.U Keyword Researcher — 환경변수 예시
# =====================================================================
# 이 파일을 `.env`로 복사한 뒤 값을 채우세요.

# ── 스토리지 백엔드 선택 ────────────────────────────────────────────────
# auto    : 자격증명/시트 있으면 mirror, 없으면 local (권장)
# mirror  : Local + Google Sheets 양방향 동기화
# sheets  : Google Sheets 단독
# local   : Local 단독 (xlsx 또는 csv)
OSMU_STORAGE_BACKEND=auto

# ── 로컬 파일 형식 ──────────────────────────────────────────────────
# xlsx (권장 — Excel/Numbers에서 직접 열림) / csv
OSMU_LOCAL_FORMAT=xlsx
OSMU_LOCAL_XLSX=osmu_workbook.xlsx
OSMU_LOCAL_DATA_DIR=./data

# ── Google Sheets 연동 ────────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service_account.json
OSMU_SHEET_ID=
OSMU_SHEET_TITLE=OSMU_content_db
OSMU_WS_KEYWORD_POOL=keyword_pool
OSMU_WS_CONTENT_DB=content_db

# ── 평가 모듈 ──────────────────────────────────────────────────────────
# heuristic    : 내장 휴리스틱 (기본)
# naver_golden : 네이버 DataLab + Blog + Google Trends + 상업의도 (사용자 황금 키워드 분석기 통합)
# naver_ads    : 네이버 검색광고 API (stub)
OSMU_EVALUATOR=heuristic

# 네이버 오픈 API (naver_golden 평가기용)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_DATALAB_CLIENT_ID=
NAVER_DATALAB_CLIENT_SECRET=

# ── 풀 정책 ──────────────────────────────────────────────────────────
OSMU_POOL_MAX_SIZE=200
OSMU_REVIVAL_DAYS=30
OSMU_SEED_COOLDOWN_DAYS=7
OSMU_GOLDEN_THRESHOLD=70
OSMU_MEDIUM_LOWER=40
OSMU_MEDIUM_UPPER=70

# ── 콘텐츠 생성 모듈 (content_generator) ─────────────────────────────────
# Firecrawl — 검색 + 페이지 크롤링 (https://firecrawl.dev)
FIRECRAWL_API_KEY=

# Anthropic API — SEO 글 생성 (Pro 구독과 별개. Token 기반 과금)
ANTHROPIC_API_KEY=

# Unsplash — 본문 이미지 (없으면 picsum.photos 자동 폴백)
UNSPLASH_ACCESS_KEY=
