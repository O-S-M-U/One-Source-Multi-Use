# =====================================================================
# O.S.M.U Keyword Researcher — 환경변수 예시
# =====================================================================
# 이 파일을 `.env`로 복사한 뒤 값을 채우세요.

# ── 스토리지 백엔드 (운영 default: PostgreSQL) ────────────────────────
# auto     : DATABASE_URL 있으면 postgres, 없으면 mirror/local 폴백
# postgres : PostgreSQL + pgvector — Neon 등 (운영 권장)
# mirror   : Local + Google Sheets 양방향 동기화
# sheets   : Google Sheets 단독
# local    : Local 단독 (xlsx/csv) — 임시 폴백용
OSMU_STORAGE_BACKEND=auto

# ── PostgreSQL 백엔드 (Neon 권장) ──────────────────────────────────────
# Neon:     postgresql://USER:PASS@ep-xxx-xxxxx.region.aws.neon.tech/dbname?sslmode=require
# Supabase: postgresql://postgres:PASS@db.PROJECT.supabase.co:5432/postgres
# 로컬 docker: postgresql://osmu:osmu@localhost:5432/osmu
OSMU_DATABASE_URL=
OSMU_DB_POOL_MIN=1
OSMU_DB_POOL_MAX=4

# ── 로컬 파일 형식 ──────────────────────────────────────────────────
# xlsx (권장 — Excel/Numbers에서 직접 열림) / csv
OSMU_LOCAL_FORMAT=xlsx
OSMU_LOCAL_XLSX=osmu_workbook.xlsx
OSMU_LOCAL_DATA_DIR=./data

# ── Google Sheets 연동 ────────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service_account.json
OSMU_SHEET_ID=
OSMU_SHEET_TITLE=OSMU_content_db
OSMU_WS_KEYWORD_POOL=keyword_pool
OSMU_WS_CONTENT_DB=content_db

# ── 평가 모듈 ──────────────────────────────────────────────────────────
# heuristic    : 내장 휴리스틱 (기본)
# naver_golden : 네이버 DataLab + Blog + Google Trends + 상업의도 (사용자 황금 키워드 분석기 통합)
# naver_ads    : 네이버 검색광고 API (stub)
OSMU_EVALUATOR=heuristic

# 네이버 오픈 API (naver_golden 평가기용)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_DATALAB_CLIENT_ID=
NAVER_DATALAB_CLIENT_SECRET=

# 네이버 검색광고 API (score-3/score-4) — 절대 월 검색량 + 연관 키워드
# searchad.naver.com → 도구 > API 사용 관리
NAVER_SEARCHAD_API_KEY=
NAVER_SEARCHAD_SECRET_KEY=
NAVER_SEARCHAD_CUSTOMER_ID=

# Google Custom Search (next-5) — 외부 표절 광역 검사
OSMU_GOOGLE_CSE_KEY=
OSMU_GOOGLE_CSE_CX=

# Tistory Playwright 실 발행 가드 (next-7/ops) — 의도치 않은 발행 방지
# 실 발행 시에만 "1" 로
OSMU_PUBLISH_REAL=
# in_progress lock timeout (ops-5)
OSMU_CHECKER_VERIFY_LINKS=
OSMU_HOUSEKEEPING_INPROGRESS_TIMEOUT_HOURS=24

# ── v13 config 임계치 — env > DB config > 코드 default 우선순위 ─────
# 모든 dot notation 키는 OSMU_ prefix + 대문자 + underscore 자동 매핑.
#   keyword.pool_max_size      → OSMU_KEYWORD_POOL_MAX_SIZE
#   collector.min_blogs        → OSMU_COLLECTOR_MIN_BLOGS
# 비워두면 DB config 또는 코드 default 사용.

# keyword.* (1단계 — keyword_researcher)
OSMU_KEYWORD_POOL_MAX_SIZE=50
OSMU_KEYWORD_POOL_EVICTION_SCORE_THRESHOLD=45
OSMU_KEYWORD_POOL_EVICTION_EVAL_COUNT=3
OSMU_KEYWORD_REVIVAL_DAYS=30
OSMU_KEYWORD_REUSE_DAYS=180
OSMU_KEYWORD_SIMILARITY_COOLDOWN_THRESHOLD=0.85
OSMU_KEYWORD_SIMILARITY_COOLDOWN_DAYS=3
OSMU_KEYWORD_RECENT_DENSITY_WINDOW_DAYS=14
OSMU_KEYWORD_GOLDEN_THRESHOLD=60
OSMU_KEYWORD_SEED_DUPLICATE_THRESHOLD=0.93

# collector.* (2단계 — collector Phase 1·2)
OSMU_COLLECTOR_MIN_BLOGS=3
OSMU_COLLECTOR_SIMILARITY_WARNING_THRESHOLD=0.75

# checker.* (4단계 — checker Stage 1)
OSMU_CHECKER_PLAGIARISM_OVERALL_THRESHOLD=0.15
OSMU_CHECKER_PLAGIARISM_SENTENCE_THRESHOLD=0.35
OSMU_CHECKER_MIN_CHAR_COUNT=1500

# publisher.* (5단계 — publisher 발행 게이트)
OSMU_PUBLISHER_DAILY_LIMIT=2
OSMU_PUBLISHER_MIN_DRAFT_MINUTES=30
OSMU_PUBLISHER_SIMILARITY_COOLDOWN_THRESHOLD=0.85
OSMU_PUBLISHER_SIMILARITY_COOLDOWN_DAYS=3

# ── legacy 호환 (구 환경변수 이름도 fallback 으로 인식) ───────────
# OSMU_POOL_MAX_SIZE / OSMU_REVIVAL_DAYS / OSMU_SEED_COOLDOWN_DAYS / OSMU_GOLDEN_THRESHOLD

# ── 콘텐츠 생성 모듈 (content_generator) ─────────────────────────────────
# Firecrawl — 검색 + 페이지 크롤링 (https://firecrawl.dev)
FIRECRAWL_API_KEY=

# Anthropic API — SEO 글 생성 (Pro 구독과 별개. Token 기반 과금)
ANTHROPIC_API_KEY=

# Unsplash — 본문 이미지 (없으면 picsum.photos 자동 폴백)
UNSPLASH_ACCESS_KEY=
